# 🔐 Fortune Cookie AI - 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ========================================
# 🤖 AI 服务配置 (必需)
# ========================================
# OpenRouter API 密钥 - 用于 AI 消息生成功能
# 获取地址: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# 可选: 指定 OpenRouter 模型 (默认: openai/gpt-4o-mini)
OPENROUTER_MODEL=openai/gpt-4o-mini

# ========================================
# 📊 分析和 SEO 配置 (推荐)
# ========================================
# Google Analytics 4 跟踪 ID
# 格式: G-XXXXXXXXXX
GOOGLE_ANALYTICS_ID=your_google_analytics_id

# Google Search Console 验证码
# 从 Google Search Console 获取
GOOGLE_VERIFICATION_CODE=your_google_verification_code

# Google AdSense 客户端 ID (可选)
# 格式: ca-pub-XXXXXXXXXXXXXXXX
# 获取地址: https://www.google.com/adsense/
# ⚠️ 安全提醒: 请勿在此文件中填写真实的 AdSense ID
# 请在 .env.local 或部署平台的环境变量中配置
GOOGLE_ADSENSE_CLIENT_ID=ca-pub-XXXXXXXXXXXXXXXX

# ========================================
# 🌐 应用程序配置
# ========================================
# 应用程序的完整 URL (生产环境请修改)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# 应用程序名称
NEXT_PUBLIC_APP_NAME=Fortune Cookie AI

# ========================================
# 🔐 Auth (NextAuth + Google OAuth)
# ========================================
# NextAuth.js 运行时 URL
NEXTAUTH_URL=http://localhost:3000

# NextAuth.js 加密密钥 (建议使用 openssl rand -base64 32)
NEXTAUTH_SECRET=your_nextauth_secret

# Google OAuth 凭证 (Web)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ========================================
# 📱 Mobile Authentication (iOS App)
# ========================================
# Apple Sign In - Bundle ID
# 用于验证 Apple Identity Token
APPLE_BUNDLE_ID=com.brucelee.FortuneCookieAI

# Google Sign In - iOS Client ID
# 用于验证 Google ID Token (iOS 专用)
# 获取地址: https://console.cloud.google.com/apis/credentials
GOOGLE_IOS_CLIENT_ID=781267846794-3mnq8a4lppp2b3o6khm7iikv3t4s7juo.apps.googleusercontent.com

# ========================================
# 🛡️ 安全和限制配置 (可选)
# ========================================
# API 请求速率限制 - 每个时间窗口的最大请求数
RATE_LIMIT_MAX_REQUESTS=100

# 速率限制时间窗口 (毫秒) - 默认 15 分钟
RATE_LIMIT_WINDOW_MS=900000

# API 密钥 (可选) - 用于增强速率限制
# 格式: 逗号分隔的密钥列表
# 公共访问: 10 请求/分钟 (无需 API 密钥)
# 认证访问: 100 请求/分钟 (需要有效的 API 密钥)
# 使用方法: 在请求头中添加 x-api-key: your_api_key_here
# API_KEYS=key_dev_123,key_prod_456,key_partner_789

# ========================================
# 🎯 每日配额配置
# ========================================
# 未登录用户每日生成次数
GUEST_DAILY_LIMIT=1

# 已登录用户每日生成次数
AUTH_DAILY_LIMIT=10

# ========================================
# 🚀 部署配置 (生产环境)
# ========================================
# 生产环境示例:
# NEXT_PUBLIC_APP_URL=https://your-domain.com
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# GOOGLE_VERIFICATION_CODE=your_actual_verification_code

# ========================================
# 📝 配置说明
# ========================================
# 1. AI 功能需要 OPENROUTER_API_KEY，未配置时会使用静态消息
# 2. Google Analytics 用于用户行为分析和 SEO 监控
# 3. 生产环境部署时请更新 NEXT_PUBLIC_APP_URL
# 4. 速率限制可防止 API 滥用，根据需要调整

# ========================================
# 🚀 缓存和性能配置 (推荐)
# ========================================
# Upstash Redis - 用于分布式缓存和限流
# 获取地址: https://upstash.com/
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# 缓存管理员令牌 (用于缓存管理API - 向后兼容)
CACHE_ADMIN_TOKEN=your_cache_admin_token

# ========================================
# 🔐 API 签名验证配置 (推荐)
# ========================================
# API 签名密钥 - 用于请求签名验证
API_KEY_ID=your_api_key_id
API_KEY_SECRET=your_api_key_secret
API_KEY_PERMISSIONS=cache:manage,analytics:read,admin

# API 签名密钥 (开发环境)
API_SIGNATURE_SECRET=your_dev_signature_secret

# ========================================
# 🗄️ 数据库配置 (推荐)
# ========================================
# PostgreSQL 数据库连接 URL
# 本地开发示例 (需要先启动 PostgreSQL 服务):
# DATABASE_URL="postgresql://username:password@localhost:5432/fortune_cookie_db"
#
# 生产环境示例 (托管数据库):
# DATABASE_URL="postgresql://user:pass@host:5432/dbname?sslmode=require"
#
# 推荐的托管 PostgreSQL 服务:
# - Neon: https://neon.tech/ (免费层支持)
# - Supabase: https://supabase.com/ (免费层支持)
# - Railway: https://railway.app/ (简单部署)
# - Vercel Postgres: https://vercel.com/storage/postgres
DATABASE_URL="postgresql://username:password@localhost:5432/fortune_cookie_db"

# 数据库连接 URL (无连接池)
DATABASE_URL_UNPOOLED="postgresql://username:password@host:5432/dbname?sslmode=require"

# PostgreSQL 连接参数
PGHOST=your_postgres_host
PGHOST_UNPOOLED=your_postgres_host_unpooled
PGUSER=your_postgres_user
PGDATABASE=your_postgres_database
PGPASSWORD=your_postgres_password

# Vercel Postgres 兼容参数
POSTGRES_URL="postgresql://username:password@host:5432/dbname?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://username:password@host:5432/dbname?sslmode=require"
POSTGRES_USER=your_postgres_user
POSTGRES_HOST=your_postgres_host
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=your_postgres_database
POSTGRES_URL_NO_SSL="postgresql://username:password@host:5432/dbname"
POSTGRES_PRISMA_URL="postgresql://username:password@host:5432/dbname?connect_timeout=15&sslmode=require"

# Neon Auth 配置 (如果使用 Neon Auth)
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your_stack_publishable_key
STACK_SECRET_SERVER_KEY=your_stack_secret_key

# 数据库连接池配置 (PostgreSQL 优化)
DB_CONNECTION_LIMIT=10
DB_QUERY_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=5000
DB_SLOW_QUERY_THRESHOLD=1000

# 数据库管理员令牌 (用于数据库管理 API)
DATABASE_ADMIN_TOKEN=your_database_admin_token


# ========================================
# 🔍 IndexNow SEO 配置
# ========================================
# IndexNow 用于即时通知搜索引擎内容更新
# 文档: https://www.indexnow.org/documentation

# 网站主机名（不包含协议）
INDEXNOW_HOST=fortune-cookie.cc

# IndexNow 管理员令牌（用于 API 路由认证）
# 建议使用强随机字符串: openssl rand -hex 32
INDEXNOW_ADMIN_TOKEN=your_indexnow_admin_token

# ========================================
# 📝 内容自动生成配置 (Content Pipeline)
# ========================================
# Tavily Web Search API 密钥 — 用于自动选题
# 获取地址: https://app.tavily.com
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# 内容生成默认模型 (OpenRouter model ID)
# 示例: x-ai/grok-4.1-fast, anthropic/claude-sonnet-4-20250514, google/gemini-2.5-flash
CONTENT_GENERATION_MODEL=x-ai/grok-4.1-fast

# 内容生成 API 路由认证令牌
# 建议: openssl rand -hex 32
CONTENT_ADMIN_TOKEN=your_content_admin_token_here

# 生成后自动翻译到 zh/es/pt
# "true" 启用, "false" 禁用 (默认 false)
CONTENT_AUTO_TRANSLATE=false

# 生成后自动通知 IndexNow 搜索引擎
# "true" 启用, "false" 禁用 (默认 false)
CONTENT_AUTO_INDEXNOW=false

# ========================================
# 🔒 安全提醒
# ========================================
# ⚠️  重要：永远不要将包含真实密钥的 .env.local 文件提交到 git
# ⚠️  生产环境请在部署平台的环境变量中配置，不要在代码中硬编码
# ⚠️  定期轮换 API 密钥以确保安全性
